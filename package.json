{
  "name": "obsidian-memory-mcp",
  "version": "1.0.0",
  "description": "MCP server that stores AI memories as Markdown files for visualization in Obsidian's graph view",
  "license": "MIT",
  "author": "YuNaga224 (https://github.com/YuNaga224)",
  "repository": {
    "type": "git",
    "url": "https://github.com/YuNaga224/obsidian-memory-mcp.git"
  },
  "keywords": [
    "mcp",
    "obsidian",
    "memory",
    "markdown",
    "knowledge-graph"
  ],
  "type": "module",
  "bin": {
    "obsidian-memory-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && shx chmod +x dist/*.js",
    "prepare": "npm run build",
    "watch": "tsc --watch",
    "start": "node dist/index.js",
    "daemon": "node dist/standalone-watcher.js",
    "index": "tsx scripts/index.ts",
    "stats": "tsx scripts/stats.ts",
    "reindex": "tsx scripts/index.ts --force",
    "docs": "typedoc",
    "docs:watch": "typedoc --watch",
    "docs:serve": "npx http-server docs/api -p 8080"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.20.0",
    "@types/pg": "^8.15.5",
    "chokidar": "^4.0.3",
    "gray-matter": "^4.0.3",
    "pg": "^8.16.3",
    "stopword": "^3.1.1",
    "winston": "^3.18.3",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.18.8",
    "@types/stopword": "^2.0.3",
    "shx": "^0.3.4",
    "tsx": "^4.20.6",
    "typedoc": "^0.28.14",
    "typedoc-plugin-markdown": "^4.9.0",
    "typescript": "^5.6.2"
  }
}
